##" Malloyyo internal analytics — sources over the application's own Postgres database."

// ── Base sources (no joins, just measures + dimensions) ──────────────────────

source: users_base is malloyyo_db.table('public.users') extend {
  primary_key: id
  measure:
    user_count is count()
    admin_count is count() { where: is_admin = true }
}

source: datasets_base is malloyyo_db.table('public.datasets') extend {
  primary_key: id
  measure:
    dataset_count is count()
    ready_count is count() { where: status::string = 'ready' }
    failed_count is count() { where: status::string = 'failed' }
    public_count is count() { where: is_public = true }
}

source: malloy_models_base is malloyyo_db.table('public.malloy_models') extend {
  primary_key: id
  measure:
    model_count is count()
    errored_count is count() { where: compile_error is not null }
  dimension:
    has_error is compile_error is not null
}

source: malloy_model_files_base is malloyyo_db.table('public.malloy_model_files') extend {
  primary_key: id
  measure:
    file_count is count()
  dimension:
    extension is substr(path, strpos(path, '.'))
}

source: conversations_base is malloyyo_db.table('public.conversations') extend {
  primary_key: id
  measure:
    conversation_count is count()
  dimension:
    created_date is created_at.day
}

source: inquiries_base is malloyyo_db.table('public.inquiries') extend {
  primary_key: id
  measure:
    inquiry_count is count()
  dimension:
    created_date is created_at.day
}

source: tool_calls_base is malloyyo_db.table('public.tool_calls') extend {
  primary_key: id
  rename: mcp_source is `source`
  measure:
    tool_call_count is count()
    error_count is count() { where: error is not null }
    success_count is count() { where: error is null }
    avg_duration_ms is avg(duration_ms)
    total_rows_returned is sum(row_count)
    compile_error_count is count() { where: tool_name = 'compile_analytical_query' and error is not null }
  dimension:
    has_error is error is not null
    created_date is created_at.day
}

source: queries_base is malloyyo_db.table('public.queries') extend {
  primary_key: id
  measure:
    query_count is count()
    error_count is count() { where: error is not null }
    success_count is count() { where: error is null }
    avg_duration_ms is avg(duration_ms)
    total_rows_returned is sum(row_count)
  dimension:
    has_error is error is not null
    created_date is created_at.day
    source_name is regexp_extract(malloy_source, r'run: ([A-Za-z0-9_]+)[-\s]')
}

// ── Main sources (with joins) ─────────────────────────────────────────────────
##" Internal data fro Malloyyo's own usage, pulled from the application's Postgres database. 

#" Malloyyo registered user accounts.
source: users is users_base extend {
  view: by_day is {
    group_by: created_at.day
    aggregate: user_count
  }
}

#" Malloy datasets (GitHub repos) added by users.
source: datasets is datasets_base extend {
  join_one: user is users_base on user_id = user.id
  view: by_status is {
    group_by: status
    aggregate: dataset_count
  }
}

#" Compiled Malloy model versions. Each dataset refresh creates a new version.
source: malloy_models is malloy_models_base extend {
  join_one: dataset is datasets_base on dataset_id = dataset.id
  view: show_models is {
    group_by: dataset.name
    nest: sources is {
      group_by: source_definition is sources::string
      limit: 1
    }
    aggregate:
      version_count is count(version)
      first_created is min(created_at)
      last_updated is max(created_at)
    order_by: last_updated desc
    limit: 20
  }
}

#" Individual .malloy files stored per model version.
source: malloy_model_files is malloy_model_files_base extend {
  join_one: model is malloy_models_base on model_id = model.id
}

#" A conversation is a session with a data source — one per claude.ai chat.
source: conversations is conversations_base extend {
  join_one: user is users_base on user_id = user.id
  join_one: dataset is datasets_base on dataset_id = dataset.id
  join_many: inquiries is inquiries_base on id = inquiries.conversation_id

  # dashboard
  view: by_user_and_conversation is {
    group_by: user.name, user.email
    aggregate: conversation_count
    nest: conversations is {
      group_by: created_date, context
      aggregate: inquiries.inquiry_count
      # list
      nest: inquiries is {
        group_by: inquiries.question
      }
    }
    order_by: conversation_count desc
  }
  view: by_user is {
    group_by: user.email
    aggregate: conversation_count
    order_by: conversation_count desc
  }
  view: recent is {
    group_by: user.email, context, created_at
    aggregate: inq_count is inquiries.inquiry_count
    order_by: created_at desc
    limit: 20
  }
}

#" An inquiry is a single question within a conversation.
source: inquiries is inquiries_base extend {
  join_one: conversation is conversations_base on conversation_id = conversation.id
  join_many: tool_calls is tool_calls_base on id = tool_calls.inquiry_id
  view: by_tool_count is {
    group_by: question
    aggregate:
      tc_count is tool_calls.tool_call_count
      tc_errors is tool_calls.error_count
    order_by: tc_count desc
    limit: 20
  }
  view: with_errors is {
    having: tool_calls.error_count > 0
    group_by: question, conversation.context
    aggregate:
      tc_count is tool_calls.tool_call_count
      tc_errors is tool_calls.error_count
    order_by: tc_errors desc
    limit: 20
  }
}

#" Individual MCP tool calls, sequenced within an inquiry.
source: tool_calls is tool_calls_base extend {
  join_one: inquiry is inquiries_base on inquiry_id = inquiry.id
  join_one: conversation is conversations_base on inquiry.conversation_id = conversation.id
  join_one: user is users_base on user_id = user.id
  join_one: dataset is datasets_base on dataset_id = dataset.id
  view: by_tool is {
    group_by: tool_name
    aggregate: tool_call_count, error_count, avg_duration_ms
  }
  view: by_day is {
    group_by: created_date
    aggregate: tool_call_count, error_count
  }
  view: compile_errors is {
    where: tool_name = 'compile_analytical_query' and has_error
    group_by: error, mcp_source, inquiry.question
    aggregate: tool_call_count
    order_by: tool_call_count desc
    limit: 50
  }
  view: by_inquiry is {
    group_by: inquiry.question, conversation.context, user.email
    aggregate: tool_call_count, error_count
    order_by: tool_call_count desc
    limit: 20
  }
}

#" Analytical queries run via the MCP endpoint (legacy — superseded by tool_calls).
source: queries is queries_base extend {
  join_one: user is users_base on user_id = user.id
  join_one: dataset is datasets_base on dataset_id = dataset.id
  view: by_source is {
    group_by: source_name
    aggregate: query_count, error_count, avg_duration_ms
  }
  view: by_day is {
    group_by: created_date
    aggregate: query_count, error_count, avg_duration_ms
  }
  view: by_user is {
    group_by: user.email
    aggregate: query_count, error_count, avg_duration_ms
    order_by: query_count desc
  }
  view: slowest is {
    order_by: duration_ms desc
    select: malloy_source, duration_ms, row_count, created_at
    limit: 20
  }
}
